# Copy this file to local.properties (do not commit local.properties)
# Debug key should be restricted for development usage.
WEATHER_API_KEY_DEBUG=your_openweather_debug_key

# Release key should be dedicated for production usage.
WEATHER_API_KEY_RELEASE=your_openweather_release_key

# Public OSM tile URL for prototype.
MAP_TILE_BASE_URL=https://tile.openstreetmap.org

# Optional API key (leave empty for public providers like OSM).
MAP_TILE_API_KEY=
