<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.weatherwise.controller.DashboardController"
            fitToWidth="true"
            style="-fx-background-color: #f6f7f8;
                   -fx-background: #f6f7f8;
                   -fx-border-width: 0;">

    <VBox spacing="28" style="-fx-padding: 32 36 32 36; -fx-background-color: #f6f7f8;">

        <!-- Status label (loading / error) -->
        <Label fx:id="labelStatus" text=""
               visible="false"
               style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>

        <!-- ===================== HERO SECTION ===================== -->
        <HBox spacing="24" alignment="CENTER_LEFT">

            <!-- Kiri: Info Cuaca Utama -->
            <VBox spacing="8" HBox.hgrow="ALWAYS">

                <!-- Lokasi -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="mdi2m-map-marker"
                              iconSize="16" iconColor="#2b8cee"/>
                    <Label fx:id="labelCity"
                           text="Memuat..."
                           style="-fx-font-size: 13px;
                                  -fx-font-weight: 600;
                                  -fx-text-fill: #2b8cee;"/>
                </HBox>

                <!-- Tanggal -->
                <Label fx:id="labelDate"
                       text=""
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #94a3b8;"/>

                <!-- Suhu Besar + Icon -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <HBox alignment="BASELINE_LEFT" spacing="4">
                        <Label fx:id="labelTemp" text="--"
                               style="-fx-font-size: 88px;
                                      -fx-font-weight: 900;
                                      -fx-text-fill: #0f172a;"/>
                        <Label text="°C"
                               style="-fx-font-size: 36px;
                                      -fx-font-weight: 700;
                                      -fx-text-fill: #2b8cee;
                                      -fx-padding: 0 0 20 0;"/>
                    </HBox>

                    <VBox alignment="CENTER" spacing="6">
                        <FontIcon fx:id="iconWeather"
                                  iconLiteral="mdi2w-weather-sunny"
                                  iconSize="72"
                                  iconColor="#f59e0b"/>
                        <Label fx:id="labelCondition" text="--"
                               style="-fx-font-size: 15px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #475569;"/>
                    </VBox>
                </HBox>

                <!-- High / Low / Feels Like -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <HBox spacing="4" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="mdi2a-arrow-up-thick"
                                  iconSize="14" iconColor="#94a3b8"/>
                        <Label fx:id="labelHigh" text="--°"
                               style="-fx-font-weight: bold;
                                      -fx-text-fill: #64748b;
                                      -fx-font-size: 13px;"/>
                    </HBox>
                    <HBox spacing="4" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="mdi2a-arrow-down-thick"
                                  iconSize="14" iconColor="#94a3b8"/>
                        <Label fx:id="labelLow" text="--°"
                               style="-fx-font-weight: bold;
                                      -fx-text-fill: #64748b;
                                      -fx-font-size: 13px;"/>
                    </HBox>
                    <Label text="|" style="-fx-text-fill: #e2e8f0;"/>
                    <Label fx:id="labelFeelsLike" text="Feels like --°C"
                           style="-fx-text-fill: #64748b;
                                  -fx-font-size: 13px;"/>
                </HBox>

            </VBox>

            <!-- Kanan: Live Satellite Card -->
            <VBox alignment="CENTER"
                  style="-fx-background-color: #1e293b;
                         -fx-background-radius: 18;
                         -fx-pref-width: 280;
                         -fx-pref-height: 200;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 16, 0, 4);">
                <FontIcon iconLiteral="mdi2s-satellite-variant"
                          iconSize="48" iconColor="#2b8cee"/>
                <Label text="Live Satellite"
                       style="-fx-font-size: 13px;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;
                              -fx-padding: 10 0 0 0;"/>
                <Label fx:id="labelSatelliteCity" text="--"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #94a3b8;"/>
            </VBox>

        </HBox>

        <!-- ===================== HOURLY FORECAST ===================== -->
        <VBox spacing="14">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <FontIcon iconLiteral="mdi2c-clock-time-four-outline"
                          iconSize="20" iconColor="#2b8cee"/>
                <Label text="Hourly Forecast"
                       style="-fx-font-size: 17px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #0f172a;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Next 48 Hours →"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #2b8cee;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;
                               -fx-border-width: 0;"/>
            </HBox>

            <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                        fitToHeight="true"
                        style="-fx-background-color: transparent;
                               -fx-background: transparent;
                               -fx-border-width: 0;
                               -fx-padding: 0 0 8 0;">
                <HBox fx:id="hourlyContainer" spacing="10"
                      style="-fx-padding: 4 4 8 4;"/>
            </ScrollPane>
        </VBox>

        <!-- ===================== DETAIL CARDS ===================== -->
        <VBox spacing="14">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <FontIcon iconLiteral="mdi2i-information-outline"
                          iconSize="20" iconColor="#2b8cee"/>
                <Label text="Weather Details"
                       style="-fx-font-size: 17px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #0f172a;"/>
            </HBox>

            <HBox fx:id="detailContainer" spacing="16"
                  alignment="CENTER_LEFT"/>
        </VBox>

        <!-- ===================== WEEKLY HUMIDITY BAR ===================== -->
        <VBox spacing="14"
              style="-fx-background-color: white;
                     -fx-background-radius: 14;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <FontIcon iconLiteral="mdi2c-chart-bar"
                          iconSize="20" iconColor="#2b8cee"/>
                <Label text="Weekly Humidity"
                       style="-fx-font-size: 15px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #0f172a;"/>
            </HBox>
            <Pane fx:id="humidityChartContainer"
                  prefHeight="130"
                  style="-fx-background-color: transparent;"/>
        </VBox>

    </VBox>
</ScrollPane>
